---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TranslateGame from '../../components/TranslateGame.astro';
import WeeklyNews from '../../components/WeeklyNews.astro';
---

<BaseLayout
  title="InterIXW - Traducao com IA e Servicos de Voz | Traducao Automatica Neural"
  description="Traducao profissional de texto e voz impulsionada por IA para empresas e individuos. Quebre barreiras linguisticas com traducao automatica neural de ponta em mais de 100 idiomas."
  lang="pt"
>
  <Fragment slot="logo">InterIXW</Fragment>
  <Fragment slot="footer-name">InterIXW</Fragment>

  <section class="hero">
    <div class="hero-content">
      <span class="hero-pill">Servicos de Traducao com IA</span>
      <h1>InterIXW</h1>
      <span class="gradient-text">Traducao IA e Voz</span>
      <p class="lead">Traducao profissional de texto e voz impulsionada por IA para empresas e individuos. Quebre barreiras linguisticas com traducao automatica neural de ponta.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="value">100+</div>
          <div class="label">Idiomas</div>
        </div>
        <div class="hero-stat">
          <div class="value">Tempo Real</div>
          <div class="label">Traducao</div>
        </div>
        <div class="hero-stat">
          <div class="value">Voz e Texto</div>
          <div class="label">Suportados</div>
        </div>
      </div>
    </div>
  </section>

  <TranslateGame lang="pt" />

  <div class="container">
    <div class="ad-slot">Espaco Publicitario - Google AdSense</div>

    <div class="card-grid">
      <article class="card">
        <span class="card-icon">📝</span>
        <h2>Traducao de Texto</h2>
        <p>Traducao de documentos e conteudo impulsionada por IA em mais de 100 pares de idiomas. Traducao neural consciente do contexto que compreende nuances, tom e terminologia especializada.</p>
      </article>
      <article class="card">
        <span class="card-icon">🎙️</span>
        <h2>Traducao de Voz e Fala</h2>
        <p>Traducao de voz para voz em tempo real para conferencias, reunioes e chamadas. Interpretacao impulsionada por IA que captura o significado e fornece uma saida com som natural.</p>
      </article>
      <article class="card">
        <span class="card-icon">📄</span>
        <h2>Traducao de Documentos</h2>
        <p>Traducao de PDF, Word, Excel e PowerPoint preservando a formatacao original. Traducoes certificadas para documentos juridicos, medicos e oficiais.</p>
      </article>
      <article class="card">
        <span class="card-icon">🌐</span>
        <h2>Localizacao de Sites</h2>
        <p>Servicos completos de traducao e localizacao de sites. Conteudo multilingue otimizado para SEO que mantem a voz da sua marca em todos os mercados.</p>
      </article>
      <article class="card">
        <span class="card-icon">🤖</span>
        <h2>Modelos de Linguagem IA</h2>
        <p>Modelos treinados sob medida para terminologia especifica do setor. IA especializada para traducao medica, juridica e tecnica com expertise no dominio.</p>
      </article>
      <article class="card">
        <span class="card-icon">🏢</span>
        <h2>Solucoes Empresariais</h2>
        <p>Integracao API, traducao em massa, memoria de traducao e fluxos de garantia de qualidade. Solucoes escalaveis para organizacoes de qualquer porte.</p>
      </article>
    </div>

    <div class="ad-slot">Espaco Publicitario - Google AdSense</div>
  </div>

  <WeeklyNews lang="pt" />

  <div class="container">
    <div class="ad-slot">Espaco Publicitario - Google AdSense</div>
  </div>
</BaseLayout>

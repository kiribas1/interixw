---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TranslateGame from '../../components/TranslateGame.astro';
import WeeklyNews from '../../components/WeeklyNews.astro';
---

<BaseLayout
  title="InterIXW - Traduccion con IA y Servicios de Voz | Traduccion Automatica Neuronal"
  description="Traduccion profesional de texto y voz impulsada por IA para empresas e individuos. Rompa las barreras del idioma con traduccion automatica neuronal de vanguardia en mas de 100 idiomas."
  lang="es"
>
  <Fragment slot="logo">InterIXW</Fragment>
  <Fragment slot="footer-name">InterIXW</Fragment>

  <section class="hero">
    <div class="hero-content">
      <span class="hero-pill">Servicios de Traduccion con IA</span>
      <h1>InterIXW</h1>
      <span class="gradient-text">Traduccion IA y Voz</span>
      <p class="lead">Traduccion profesional de texto y voz impulsada por IA para empresas e individuos. Rompa las barreras del idioma con traduccion automatica neuronal de vanguardia.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="value">100+</div>
          <div class="label">Idiomas</div>
        </div>
        <div class="hero-stat">
          <div class="value">Tiempo Real</div>
          <div class="label">Traduccion</div>
        </div>
        <div class="hero-stat">
          <div class="value">Voz y Texto</div>
          <div class="label">Soportados</div>
        </div>
      </div>
    </div>
  </section>

  <TranslateGame lang="es" />

  <div class="container">
    <div class="ad-slot">Espacio Publicitario - Google AdSense</div>

    <div class="card-grid">
      <article class="card">
        <span class="card-icon">📝</span>
        <h2>Traduccion de Texto</h2>
        <p>Traduccion de documentos y contenido impulsada por IA en mas de 100 pares de idiomas. Traduccion neuronal consciente del contexto que comprende matices, tono y terminologia especializada.</p>
      </article>
      <article class="card">
        <span class="card-icon">🎙️</span>
        <h2>Traduccion de Voz y Habla</h2>
        <p>Traduccion de voz a voz en tiempo real para conferencias, reuniones y llamadas. Interpretacion impulsada por IA que captura el significado y ofrece un resultado de sonido natural.</p>
      </article>
      <article class="card">
        <span class="card-icon">📄</span>
        <h2>Traduccion de Documentos</h2>
        <p>Traduccion de PDF, Word, Excel y PowerPoint preservando el formato original. Traducciones certificadas para documentos legales, medicos y oficiales.</p>
      </article>
      <article class="card">
        <span class="card-icon">🌐</span>
        <h2>Localizacion de Sitios Web</h2>
        <p>Servicios completos de traduccion y localizacion de sitios web. Contenido multilingue optimizado para SEO que mantiene la voz de su marca en todos los mercados.</p>
      </article>
      <article class="card">
        <span class="card-icon">🤖</span>
        <h2>Modelos de Lenguaje IA</h2>
        <p>Modelos entrenados a medida para terminologia especifica de la industria. IA especializada para traduccion medica, legal y tecnica con experiencia en el dominio.</p>
      </article>
      <article class="card">
        <span class="card-icon">🏢</span>
        <h2>Soluciones Empresariales</h2>
        <p>Integracion API, traduccion masiva, memoria de traduccion y flujos de control de calidad. Soluciones escalables para organizaciones de cualquier tamano.</p>
      </article>
    </div>

    <div class="ad-slot">Espacio Publicitario - Google AdSense</div>
  </div>

  <WeeklyNews lang="es" />

  <div class="container">
    <div class="ad-slot">Espacio Publicitario - Google AdSense</div>
  </div>
</BaseLayout>

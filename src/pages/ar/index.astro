---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TranslateGame from '../../components/TranslateGame.astro';
import WeeklyNews from '../../components/WeeklyNews.astro';
---

<BaseLayout
  title="InterIXW - الترجمة بالذكاء الاصطناعي وخدمات الصوت | الترجمة الآلية العصبية"
  description="ترجمة احترافية للنصوص والصوت مدعومة بالذكاء الاصطناعي للشركات والأفراد. اكسر حواجز اللغة مع أحدث تقنيات الترجمة الآلية العصبية بأكثر من 100 لغة."
  lang="ar"
>
  <Fragment slot="logo">InterIXW</Fragment>
  <Fragment slot="footer-name">InterIXW</Fragment>

  <section class="hero">
    <div class="hero-content">
      <span class="hero-pill">خدمات الترجمة بالذكاء الاصطناعي</span>
      <h1>InterIXW</h1>
      <span class="gradient-text">الترجمة بالذكاء الاصطناعي والصوت</span>
      <p class="lead">ترجمة احترافية للنصوص والصوت مدعومة بالذكاء الاصطناعي للشركات والأفراد. اكسر حواجز اللغة مع أحدث تقنيات الترجمة الآلية العصبية.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="value">+100</div>
          <div class="label">لغة</div>
        </div>
        <div class="hero-stat">
          <div class="value">فوري</div>
          <div class="label">الترجمة</div>
        </div>
        <div class="hero-stat">
          <div class="value">صوت ونص</div>
          <div class="label">مدعوم</div>
        </div>
      </div>
    </div>
  </section>

  <TranslateGame lang="ar" />

  <div class="container">
    <div class="ad-slot">مساحة إعلانية - Google AdSense</div>

    <div class="card-grid">
      <article class="card">
        <span class="card-icon">📝</span>
        <h2>ترجمة النصوص</h2>
        <p>ترجمة المستندات والمحتوى بالذكاء الاصطناعي عبر أكثر من 100 زوج لغوي. ترجمة عصبية واعية بالسياق تفهم الفروق الدقيقة والنبرة والمصطلحات المتخصصة.</p>
      </article>
      <article class="card">
        <span class="card-icon">🎙️</span>
        <h2>ترجمة الصوت والكلام</h2>
        <p>ترجمة فورية من كلام إلى كلام للمؤتمرات والاجتماعات والمكالمات. ترجمة فورية مدعومة بالذكاء الاصطناعي تلتقط المعنى وتقدم مخرجات طبيعية.</p>
      </article>
      <article class="card">
        <span class="card-icon">📄</span>
        <h2>ترجمة المستندات</h2>
        <p>ترجمة ملفات PDF وWord وExcel وPowerPoint مع الحفاظ على التنسيق الأصلي. ترجمات معتمدة للمستندات القانونية والطبية والرسمية.</p>
      </article>
      <article class="card">
        <span class="card-icon">🌐</span>
        <h2>توطين المواقع الإلكترونية</h2>
        <p>خدمات ترجمة وتوطين كاملة للمواقع. محتوى متعدد اللغات محسن لمحركات البحث يحافظ على صوت علامتك التجارية عبر الأسواق.</p>
      </article>
      <article class="card">
        <span class="card-icon">🤖</span>
        <h2>نماذج لغة الذكاء الاصطناعي</h2>
        <p>نماذج مدربة خصيصا للمصطلحات الخاصة بالصناعة. ذكاء اصطناعي متخصص للترجمة الطبية والقانونية والتقنية مع خبرة في المجال.</p>
      </article>
      <article class="card">
        <span class="card-icon">🏢</span>
        <h2>حلول المؤسسات</h2>
        <p>تكامل API والترجمة بالجملة وذاكرة الترجمة وسير عمل ضمان الجودة. حلول قابلة للتطوير للمؤسسات من أي حجم.</p>
      </article>
    </div>

    <div class="ad-slot">مساحة إعلانية - Google AdSense</div>
  </div>

  <WeeklyNews lang="ar" />

  <div class="container">
    <div class="ad-slot">مساحة إعلانية - Google AdSense</div>

    <div class="registration">
      <h3>التسجيل المؤسسي</h3>
      <div class="reg-grid">
        <div class="reg-item">
          <div class="reg-label">التسجيل</div>
          <div class="reg-value">CP-000023</div>
        </div>
        <div class="reg-item">
          <div class="reg-label">المكتب المسجل</div>
          <div class="reg-value">build 21 - London (KI)</div>
        </div>
        <div class="reg-item">
          <div class="reg-label">الوكيل المسجل</div>
          <div class="reg-value">Kiribas Corporate Register</div>
        </div>
        <div class="reg-item">
          <div class="reg-label">تاريخ التأسيس</div>
          <div class="reg-value">30 يناير 2026</div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
